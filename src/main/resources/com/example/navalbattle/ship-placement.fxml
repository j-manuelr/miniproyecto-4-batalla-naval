<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.navalbattle.controller.ShipPlacementController"
            prefWidth="900" prefHeight="650">

    <!-- Heurística 1: Visibilidad del estado del sistema -->
    <top>
        <VBox alignment="CENTER" style="-fx-padding: 20;">
            <Label text="Fase de Preparación: Coloca tu flota" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
            <Label fx:id="lblStatus" text="Selecciona un barco de la lista para comenzar." textFill="#555555"/>
        </VBox>
    </top>

    <!-- Centro: El GridPane servirá como contenedor para el tablero (SRP) -->
    <center>
        <GridPane fx:id="boardGrid" alignment="CENTER" hgap="2" vgap="2">
            <!-- Las celdas se inyectan aquí desde el controlador -->
        </GridPane>
    </center>

    <!-- Derecha: Heurística 6 (Reconocimiento antes que memoria - panel visible de la flota) -->
    <right>
        <VBox spacing="15" style="-fx-padding: 20; -fx-background-color: #e9ecef;" prefWidth="250">
            <Label text="Flota Disponible" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

            <ListView fx:id="fleetListView" prefHeight="200"/>

            <!-- Heurística 7 y 3: Documentación in-situ de atajos y control -->
            <Label text="Controles:" style="-fx-font-weight: bold; -fx-padding: 10 0 0 0;"/>
            <Label text="• [R] o Clic Derecho: Rotar barco"/>
            <Label text="• [Esc]: Cancelar selección"/>
            <Label text="• Clic Izquierdo: Colocar"/>
        </VBox>
    </right>

    <!-- Abajo: Heurística 3 (Libertad del usuario) y Heurística 5 (Prevención de errores) -->
    <bottom>
        <HBox spacing="20" alignment="CENTER" style="-fx-padding: 20;">
            <Button text="Volver al Menú" onAction="#onBackToMenu" prefWidth="120"/>
            <Button text="Limpiar Tablero" onAction="#onClearBoard" prefWidth="120"/>

            <Region HBox.hgrow="ALWAYS" />

            <!-- Este botón permanece disable="true" hasta que la flota esté completa -->
            <Button fx:id="btnStartGame" text="Iniciar Partida" onAction="#onStartGame"
                    disable="true" prefWidth="150" prefHeight="40"
                    style="-fx-font-weight: bold; -fx-base: #2ecc71;"/>
        </HBox>
    </bottom>

</BorderPane>
