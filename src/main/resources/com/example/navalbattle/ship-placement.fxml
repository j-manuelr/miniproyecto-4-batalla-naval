<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.navalbattle.controller.ShipPlacementController"
            prefWidth="1120" prefHeight="740" style="-fx-background-color: #f4f4f4;">

    <top>
        <VBox alignment="CENTER" style="-fx-padding: 20;">
            <Label text="Fase de Preparación" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <Label fx:id="lblStatus" text="Selecciona un barco de la lista para comenzar." textFill="#555555"/>
        </VBox>
    </top>

    <center>
        <GridPane fx:id="boardGrid" alignment="CENTER" hgap="2" vgap="2">

        </GridPane>
    </center>


    <right>
        <VBox spacing="15" style="-fx-padding: 20; -fx-background-color: #e9ecef;" prefWidth="250">
            <Label text="Flota Disponible" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

            <ListView fx:id="fleetListView" prefHeight="200" style="-fx-background-color: #ffffff; -fx-border-color: #cccccc; -fx-border-radius: 4px;"/>


            <Label text="Controles:" style="-fx-font-weight: bold; -fx-text-fill: #333333; -fx-padding: 10 0 0 0;"/>
            <Label text="• [R] o Clic Derecho: Rotar barco" textFill="#333333"/>
            <Label text="• [Esc]: Cancelar selección" textFill="#333333"/>
            <Label text="• Clic Izquierdo: Colocar" textFill="#333333"/>
        </VBox>
    </right>

    <bottom>
        <HBox spacing="20" alignment="CENTER" style="-fx-padding: 20;">
            <Button text="Volver al Menú" onAction="#onBackToMenu" prefWidth="120" style="-fx-background-color: #f8f9fa; -fx-border-color: #cccccc; -fx-border-radius: 4px; -fx-background-radius: 4px; -fx-cursor: hand;"/>
            <Button text="Limpiar Tablero" onAction="#onClearBoard" prefWidth="120" style="-fx-background-color: #f8f9fa; -fx-border-color: #cccccc; -fx-border-radius: 4px; -fx-background-radius: 4px; -fx-cursor: hand;"/>

            <Region HBox.hgrow="ALWAYS" />

            <Button fx:id="btnStartGame" text="Iniciar Partida" onAction="#onStartGame"
                    disable="true" prefWidth="150" prefHeight="40"
                    style="-fx-font-weight: bold; -fx-base: #2ecc71; -fx-text-fill: white; -fx-cursor: hand;"/>
        </HBox>
    </bottom>

</BorderPane>